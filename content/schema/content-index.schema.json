{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mandacaru.local/schema/content-index.schema.json",
  "title": "Mandacaru Content Index",
  "type": "object",
  "required": [
    "schemaVersion",
    "appId",
    "defaultTrailId",
    "trails"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "appId": {
      "type": "string",
      "const": "mandacaru"
    },
    "defaultTrailId": {
      "type": "string",
      "minLength": 1
    },
    "trails": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "status",
          "difficulty",
          "estimatedDurationMin",
          "manifest",
          "theme",
          "tags"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9_\\-]+$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "draft",
              "published",
              "archived"
            ]
          },
          "difficulty": {
            "type": "string",
            "enum": [
              "easy",
              "normal",
              "hard"
            ]
          },
          "estimatedDurationMin": {
            "type": "integer",
            "minimum": 1
          },
          "manifest": {
            "type": "string",
            "pattern": "\\.json$"
          },
          "theme": {
            "type": "string",
            "minLength": 1
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
