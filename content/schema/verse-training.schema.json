{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mandacaru.local/schema/verse-training.schema.json",
  "title": "Mandacaru Verse Training Set",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "title",
    "source",
    "examples"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "examples": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "speaker",
          "section",
          "meter",
          "sourceStanzaId",
          "promptContext",
          "inputSeed",
          "targetLines",
          "endWords"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "speaker": {
            "type": "string",
            "enum": [
              "AB",
              "BB"
            ]
          },
          "section": {
            "type": "string"
          },
          "meter": {
            "type": "string"
          },
          "sourceStanzaId": {
            "type": "integer",
            "minimum": 1
          },
          "promptContext": {
            "type": "object",
            "required": [
              "theme",
              "tone",
              "topoi",
              "rhymeMode"
            ],
            "additionalProperties": false,
            "properties": {
              "theme": {
                "type": "string"
              },
              "tone": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "topoi": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "rhymeMode": {
                "type": "string"
              }
            }
          },
          "inputSeed": {
            "type": "string"
          },
          "targetLines": {
            "type": "array",
            "minItems": 4,
            "items": {
              "type": "string"
            }
          },
          "endWords": {
            "type": "array",
            "minItems": 4,
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
