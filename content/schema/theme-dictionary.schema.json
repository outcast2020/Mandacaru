{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mandacaru.local/schema/theme-dictionary.schema.json",
  "title": "Mandacaru Theme Dictionary",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "title",
    "contexts",
    "commonWords",
    "rareWords",
    "bonusRhymes",
    "ambientWords"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "schemaVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9_\\-]+$"
    },
    "title": {
      "type": "string"
    },
    "contexts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "commonWords": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z]+$"
      }
    },
    "rareWords": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z]+$"
      }
    },
    "bonusRhymes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "word",
          "rhymesWith"
        ],
        "additionalProperties": false,
        "properties": {
          "word": {
            "type": "string",
            "pattern": "^[a-z]+$"
          },
          "rhymesWith": {
            "type": "string",
            "pattern": "^[a-z]+$"
          }
        }
      }
    },
    "ambientWords": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z]+$"
      }
    }
  }
}
